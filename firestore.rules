rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    
    // Administrative check (can be expanded)
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /submissions/{submissionId} {
      allow create: if isSignedIn() && isValidId(submissionId) && isValidSubmission(incoming());
      // Allow read for everyone to see stats, but sensitive data protection is handled by the "Split Collection" principle (PII isolation)
      // For now, we allow list for the dashboard, but in a production app we would use a Cloud Function to aggregate or separate private data.
      allow get, list: if isSignedIn();
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['p1', 'p3', 'createdAt'])
        && data.p1 is string && data.p1.size() <= 200
        && data.p3 is string && data.p3.size() <= 200
        && data.createdAt == request.time
        && (data.p4 == null || (data.p4 is string && data.p4.size() <= 100))
        ;
    }
  }
}
