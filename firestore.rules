rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    
    // Administrative check (can be expanded)
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /submissions/{submissionId} {
      allow create: if isValidId(submissionId) && isValidSubmission(incoming());
      allow get, list: if isAdmin();
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['fullName', 'email', 'createdAt'])
        && data.fullName is string && data.fullName.size() <= 200
        && data.email is string && data.email.size() <= 200
        && data.createdAt == request.time
        && (data.whatsapp == null || (data.whatsapp is string && data.whatsapp.size() <= 50))
        && (data.interests == null || (data.interests is string && data.interests.size() <= 100))
        && (data.department == null || (data.department is string && data.department.size() <= 100))
        && (data.municipality == null || (data.municipality is string && data.municipality.size() <= 100))
        ;
    }
  }
}
