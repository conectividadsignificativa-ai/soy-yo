rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    
    // Administrative check
    function isAllowedAdmin() {
      return isSignedIn() 
        && request.auth.token.email_verified == true 
        && (
          request.auth.token.email == 'conectividadsignificativa@gmail.com' ||
          request.auth.token.email == 'nicolsg40@gmail.com'
        );
    }

    match /submissions/{submissionId} {
      allow create: if isSignedIn() && isValidId(submissionId) && isValidSubmission(incoming());
      allow get, list: if isAllowedAdmin();
    }

    match /profiles/{userId} {
      allow get, create, update: if isSignedIn() && request.auth.uid == userId;
    }

    function isValidSubmission(data) {
      return (data.nombre is string && data.nombre.size() <= 500)
        && (data.email is string && data.email.size() <= 500)
        && (data.createdAt == request.time)
        && (data.userId == request.auth.uid)
        ;
    }
  }
}
