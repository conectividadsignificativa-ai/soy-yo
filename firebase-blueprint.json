{
  "entities": {
    "BeneficiarySubmission": {
      "title": "Beneficiary Submission",
      "description": "Information collected from potential beneficiaries of the Conectividad Significativa project.",
      "type": "object",
      "properties": {
        "p1": { "type": "string", "description": "Full name" },
        "p2": { "type": "string", "description": "Birth date" },
        "p3": { "type": "string", "description": "Email" },
        "p4": { "type": "string", "description": "WhatsApp" },
        "p5": { "type": "string", "description": "Department" },
        "p6": { "type": "string", "description": "Municipality" },
        "p7": { "type": "string", "enum": ["Rural", "Urbana"] },
        "p8": { "type": "string", "description": "Age range" },
        "p9": { "type": "string", "description": "Gender Identity" },
        "p10": { "type": "string", "description": "Groups/Communities" },
        "p12": { "type": "string", "description": "Education level" },
        "p13": { "type": "string", "description": "Current situation" },
        "p14": { "type": "string", "description": "Internet usage" },
        "p32": { "type": "string", "description": "Digital skill level" },
        "p49": { "type": "string", "description": "Interests" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["p1", "p3", "createdAt"]
    }
  },
  "firestore": {
    "/submissions/{submissionId}": {
      "schema": "BeneficiarySubmission",
      "description": "Collection of chatbot submissions."
    }
  }
}
