{
  "entities": {
    "BeneficiarySubmission": {
      "title": "Beneficiary Submission",
      "description": "Information collected from potential beneficiaries of the Conectividad Significativa project.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "fecha_nac": { "type": "string" },
        "email": { "type": "string" },
        "whatsapp": { "type": "string" },
        "departamento": { "type": "string" },
        "municipio": { "type": "string" },
        "zona": { "type": "string" },
        "genero": { "type": "string" },
        "genero_otro": { "type": "string" },
        "grupos": { "type": "array" },
        "tipo_discapacidad": { "type": "array" },
        "rango_edad": { "type": "string" },
        "uso_internet_principal": { "type": "array" },
        "seguridad_percibida": { "type": "string" },
        "importancia_internet": { "type": "string" },
        "quisiera_hacer": { "type": "array" },
        "desmotivacion": { "type": "array" },
        "uso_oportunidades": { "type": "string" },
        "uso_ia": { "type": "string" },
        "uso_ia_para": { "type": "array" },
        "dispositivo_principal": { "type": "string" },
        "costo_internet": { "type": "string" },
        "interes_trabajo_digital": { "type": "string" },
        "lineas_interes": { "type": "array" },
        "areas_certificacion": { "type": "array" },
        "temas_politica": { "type": "array" },
        "forma_participar": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["nombre", "email", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Gamification profile for the user.",
      "type": "object",
      "properties": {
        "points": { "type": "integer" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/submissions/{submissionId}": {
      "schema": "BeneficiarySubmission",
      "description": "Collection of chatbot submissions."
    },
    "/profiles/{userId}": {
      "schema": "UserProfile",
      "description": "User gamification profiles."
    }
  }
}
